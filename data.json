<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Finance iOS</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>

<div class="app-container">
    <div id="view-home" class="view active-view">
        <div class="header">Summary</div>
        <div id="home-content">
            </div>
    </div>

    <div id="view-cards" class="view">
        <div class="header">Cards</div>
        <p class="placeholder-text">Detailed card analytics coming soon.</p>
    </div>
    <div id="view-bills" class="view">
        <div class="header">Bills</div>
        <p class="placeholder-text">Upcoming calendar view coming soon.</p>
    </div>
    <div id="view-loans" class="view">
        <div class="header">Loans</div>
        <p class="placeholder-text">Amortization schedules coming soon.</p>
    </div>

    <div id="view-admin" class="view">
        <div class="header">Admin</div>
        
        <div class="settings-group">
            <div class="settings-row">
                <div class="row-label">
                    <div class="icon" style="background-color: #5E5CE6;">✨</div>
                    <span>Dark Mode</span>
                </div>
                <label class="ios-toggle">
                    <input type="checkbox" id="themeToggle">
                    <span class="slider"></span>
                </label>
            </div>
        </div>

        <div class="group-title">Add New Item</div>
        <div class="settings-group">
            <div class="segmented-control">
                <input type="radio" name="itemType" value="account" id="type-account" checked>
                <label for="type-account">Account</label>
                
                <input type="radio" name="itemType" value="card" id="type-card">
                <label for="type-card">Card</label>
                
                <input type="radio" name="itemType" value="loan" id="type-loan">
                <label for="type-loan">Loan</label>
                
                <input type="radio" name="itemType" value="bill" id="type-bill">
                <label for="type-bill">Bill</label>
            </div>

            <form id="add-item-form" class="admin-form">
                <input type="text" id="itemName" placeholder="Name (e.g. Barclays, Gas, Visa)" required>
                
                <input type="number" id="itemAmount" placeholder="Balance/Amount" step="0.01" required>

                <div id="account-only-fields">
                    <div class="settings-row" style="padding: 10px 0;">
                        <span>Overdraft Facility?</span>
                        <label class="ios-toggle small">
                            <input type="checkbox" id="hasOverdraft">
                            <span class="slider"></span>
                        </label>
                    </div>
                    <input type="number" id="odLimit" placeholder="Overdraft Limit (£)" step="0.01">
                </div>

                <div id="bill-only-fields" style="display:none;">
                    <input type="number" id="billDay" placeholder="Day of month due (1-31)">
                    <select id="billFrequency">
                        <option value="Monthly">Monthly</option>
                        <option value="Quarterly">Quarterly</option>
                    </select>
                </div>

                <button type="submit" class="ios-btn">Save to Dashboard</button>
            </form>
        </div>

        <div class="admin-footer">
            <div class="version-control">App Version 2.5.0 (Build 910)</div>
            <div class="developer-mode">Deployed via GitHub Pages</div>
        </div>
    </div>

    <nav class="tab-bar">
        <div id="nav-home" class="tab-item active"><span>🏠</span><label>Home</label></div>
        <div id="nav-cards" class="tab-item"><span>💳</span><label>Cards</label></div>
        <div id="nav-bills" class="tab-item"><span>📑</span><label>Bills</label></div>
        <div id="nav-loans" class="tab-item"><span>💰</span><label>Loans</label></div>
        <div id="nav-admin" class="tab-item"><span>⚙️</span><label>Admin</label></div>
    </nav>
</div>

<script src="app.js"></script>
</body>
</html>
